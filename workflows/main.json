    {
      "parameters": {
        "jsCode": "// Prepare response text for LINE\ntry {\n  const input = $input.item.json;\n  const initialData = $('Initial Parse').item.json;\n  \n  let responseText = '';\n  \n  // Check for AI Agent output format\n  if (input.output && typeof input.output === 'string') {\n    responseText = input.output;\n  }\n  // Fallback\n  else {\n    responseText = '抱歉，我無法生成回應。請再試一次。';\n  }\n\n  // Truncate if too long (LINE has a 5000 character limit)\n  const MAX_LENGTH = 4500;\n  if (responseText.length > MAX_LENGTH) {\n    responseText = responseText.substring(0, MAX_LENGTH) + '...\\n\\n(訊息過長，已截斷)';\n  }\n\n  return {\n    json: {\n      responseText: responseText,\n      replyToken: initialData.replyToken,\n      isError: false\n    }\n  };\n} catch (error) {\n  console.error('Error in Format Response:', error);\n  return {\n    json: {\n      responseText: '系統發生錯誤，請稍後再試。',\n      replyToken: $('Initial Parse').item?.json?.replyToken,\n      isError: true\n    }\n  };\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        13616,
        2624
      ],
      "id": "3d4c1040-5123-4960-bc7e-ca8723947550",
      "name": "Format Response for LINE"
    },
    {
      "parameters": {
        "jsCode": "// Handle AI Agent errors\ntry {\n  const errorInput = $input.item.json;\n  const initialData = $('Initial Parse').item.json;\n\n  let errorMessage = '抱歉，我現在遇到一些問題。請稍後再試。';\n  let errorType = 'unknown';\n\n  if (errorInput.error) {\n    const error = errorInput.error;\n    \n    if (error.response) {\n      const statusCode = error.response.statusCode;\n      \n      if (statusCode === 429) {\n        errorMessage = '系統目前使用量較大，請稍後再試。';\n        errorType = 'rate_limit';\n      } else if (statusCode === 401 || statusCode === 403) {\n        errorMessage = '系統設定有誤，請聯絡管理員。';\n        errorType = 'auth_error';\n      } else if (statusCode >= 500) {\n        errorMessage = 'AI服務暫時無法使用，請稍後再試。';\n        errorType = 'server_error';\n      } else if (statusCode === 400) {\n        errorMessage = '訊息格式有誤，請重新輸入。';\n        errorType = 'bad_request';\n      }\n    } else if (error.code === 'ETIMEDOUT' || error.code === 'ESOCKETTIMEDOUT') {\n      errorMessage = '請求超時，請稍後再試。';\n      errorType = 'timeout';\n    }\n  }\n\n  console.error(`AI Agent Error - Type: ${errorType}, Error:`, errorInput.error);\n\n  return {\n    json: {\n      replyToken: initialData?.replyToken,\n      responseText: errorMessage,\n      errorType: errorType,\n      isError: true\n    }\n  };\n} catch (error) {\n  console.error('Error in Error Handler:', error);\n  return {\n    json: {\n      replyToken: $('Initial Parse').item?.json?.replyToken,\n      responseText: '系統發生錯誤，請稍後再試。',\n      errorType: 'handler_error',\n      isError: true\n    }\n  };\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        13616,
        2848
      ],
      "id": "f4531ae5-c589-402a-b06b-e7219984c98e",
