    {
      "parameters": {
        "jsCode": "// 格式化回應\nconst items = $input.all();\n\n// 如果是 list 操作，格式化事件列表\nif (items[0].json.action === 'list' || Array.isArray(items)) {\n  const events = items.map(item => ({\n    id: item.json.id,\n    summary: item.json.summary,\n    start: item.json.start,\n    end: item.json.end,\n    description: item.json.description || '',\n    location: item.json.location || '',\n    status: item.json.status\n  }));\n  \n  return {\n    success: true,\n    action: 'list',\n    count: events.length,\n    message: `查詢到 ${events.length} 筆行程`,\n    events: events\n  };\n}\n\n// 其他操作的回應\nconst firstItem = items[0].json;\nreturn {\n  success: true,\n  action: firstItem.action || 'unknown',\n  message: '操作成功',\n  event: {\n    id: firstItem.id,\n    summary: firstItem.summary,\n    start: firstItem.start,\n    end: firstItem.end,\n    status: firstItem.status\n  }\n};"
      },
